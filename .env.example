# Database (SQLite for local dev, PostgreSQL for production)
# This relative path creates custom.db in the db/ folder, works on any OS
DATABASE_URL=file:./db/custom.db

# Paystack — get FREE test keys at https://dashboard.paystack.com/#/settings/keys
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The public URL of your app (used for Paystack callback redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session secret for auth cookies (change this to a random string in production)
SESSION_SECRET=rafaab-dev-secret-change-in-production-9f2k4
