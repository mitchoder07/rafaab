# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/

# production
/build

# database (ignore .db files but keep the db/ folder with a .gitkeep)
*.db
*.db-journal
/db/*.db
/db/*.db-journal
!/db/.gitkeep

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (keep .env.example, ignore .env)
.env
.env.local
.env.*.local

# logs
dev.log
server.log

# os files
.DS_Store
Thumbs.db

# ide
.vscode/
.idea/

# upload directory (user screenshots)
/upload/

# seed images are tracked (needed for seeding) — do NOT ignore
